<h1>My To-Do List</h1>

<p><%= link_to 'Add New Task', new_task_path, class: 'btn' %></p>

<% @tasks.each do |task| %>
  <div class="task-item">
    <h3><%= task.title %></h3>
    <p><%= task.description %></p>
    <p>Status: <strong><%= task.status.capitalize %></strong></p>
    <p>
      <%= link_to 'Edit', edit_task_path(task), class: 'btn' %>
      <%= link_to 'Delete', task, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn' %>
    </p>
  </div>
<% end %>
